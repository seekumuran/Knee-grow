import { Box } from "@react-three/drei";

import { forwardRef } from "react";

const Enemy = forwardRef(function Enemy(props, ref) {

  return (

    <Box
      ref={ref}
      args={[1.5, 3, 1.5]}
      position={[5, 1.5, 0]}
      castShadow
      receiveShadow
    >

      <meshStandardMaterial color="#ff0033" />

    </Box>

  );
});

export default Enemy;
